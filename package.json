{
  "name": "x402-ptoken-launchpad",
  "private": true,
  "workspaces": [
    "shared",
    "facilitator",
    "launchpad",
    "agent-sdk",
    "perps",
    "programs",
    "p-memo-main",
    "examples"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "clean": "npm run clean --workspaces",
    "lint": "npm run lint --workspaces",
    "memo:build": "npm --prefix p-memo-main run build",
    "memo:test": "npm --prefix p-memo-main run test",
    "memo:build-sbf": "npm --prefix p-memo-main run build:sbf",
    "format": "prettier --write '**/*.{ts,js,json,md}'",
    "ptoken:launcher": "npm --prefix p-token-launcher start",
    "ptoken:launcher:check": "npm --prefix p-token-launcher run check"
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "typescript": "^5.7.0"
  }
}
